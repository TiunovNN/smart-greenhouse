# Copy this file to secrets.yaml and fill in real values.
# secrets.yaml is gitignored — never commit credentials.

# IoT Wi-Fi network (see design doc section 3.2)
wifi_ssid_iot: "IoT-GH"
wifi_password_iot: "your-long-wifi-password"

# API encryption key for ESPHome ↔ Home Assistant communication.
# Generate with: esphome secrets generate-key
# Or from the ESPHome dashboard when adding a new device.
api_encryption_key: "paste-32-byte-base64-key-here"

# OTA update password (choose a strong unique password)
ota_password: "your-ota-password"

# Fallback AP password (used when Wi-Fi is unavailable)
ap_fallback_password: "your-fallback-ap-password"
